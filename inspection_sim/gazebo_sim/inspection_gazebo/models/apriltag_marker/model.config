<?xml version="1.0" ?>
<model>
  <name>apriltag_marker</name>
  <version>1.0</version>
  <sdf version="1.6">model.sdf</sdf>

  <author>
    <name>Thanh Nguyen Canh</name>
    <email>canhthanh@vnu.edu.vn</email>
  </author>

  <description>
    Flat AprilTag fiducial marker (0.30 m, tag36h11) for rack-face anchors and the
    charging dock. Texture/material convention reused from the precise-landing pad
    so it renders identically. NOTE: all instances currently share one tag texture
    (id 0); per-anchor unique tag36h11 textures are a follow-up (see package README).
  </description>
</model>
