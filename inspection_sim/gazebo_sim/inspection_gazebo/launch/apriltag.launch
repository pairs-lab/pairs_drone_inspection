<?xml version="1.0"?>
<launch>
  <arg name="uav_name" default="uav1" />
  
  <!-- use infral camera -->
  <arg name="camera_namespace" default="$(arg uav_name)/front_rgbd/infra1" />
  <arg name="image_topic" default="image_raw" />

  <node pkg="apriltag_ros" type="apriltag_ros_continuous_node" name="apriltag_ros_continuous_node" clear_params="true" output="screen" ns="$(arg uav_name)">
    
    <remap from="image_rect" to="/$(arg camera_namespace)/$(arg image_topic)" />
    <remap from="camera_info" to="/$(arg camera_namespace)/camera_info" />

    <param name="camera_frame" type="str" value="$(arg uav_name)/front_rgbd/infra1_optical" />
    
    <param name="publish_tag_detections_image" type="bool" value="true" />

    <rosparam command="load" file="$(find inspection_gazebo)/config/settings.yaml" />
    <rosparam command="load" file="$(find inspection_gazebo)/config/tags.yaml" />
  </node>
</launch>