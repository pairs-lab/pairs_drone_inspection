<?xml version="1.0"?>
<!--
  Rack/bin AprilTag detector on the REAL forward RealSense (mirrors the sim
  inspection_gazebo/apriltag.launch, repointed at the physical camera). Publishes
  /<uav>/tag_detections (+ tag_detections_image) that inspection_core's panel consumes for
  the anchor-tag relative navigation.
-->
<launch>
  <arg name="uav_name"         default="$(optenv UAV_NAME uav1)" />
  <!-- D455 colour stream by default; switch to infra1 for low-light warehouses -->
  <arg name="camera_namespace" default="$(arg uav_name)/front_rgbd/color" />
  <arg name="image_topic"      default="image_raw" />
  <arg name="camera_frame"     default="$(arg uav_name)/front_rgbd_color_optical_frame" />

  <node pkg="apriltag_ros" type="apriltag_ros_continuous_node" name="apriltag_ros_continuous_node"
        clear_params="true" output="screen" ns="$(arg uav_name)">

    <remap from="image_rect"  to="/$(arg camera_namespace)/$(arg image_topic)" />
    <remap from="camera_info" to="/$(arg camera_namespace)/camera_info" />

    <param name="camera_frame" type="str" value="$(arg camera_frame)" />
    <param name="publish_tag_detections_image" type="bool" value="true" />

    <rosparam command="load" file="$(find inspection_real)/config/apriltag/apriltag_real.yaml" />
  </node>
</launch>
